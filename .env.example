VITE_SUPABASE_URL=https://fkkferectwhjqpeuqqnm.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
GEMINI_API_KEY=your-gemini-key-here

# Google Maps key — used by the /api/places proxy for the search box.
# Without this, search falls back to Nominatim (slower + sparser).
# The 3D Tiles key (VITE_GOOGLE_3DTILES_KEY) is read as a fallback if
# Places API (New) is enabled on it — but a dedicated key is cleaner.
# Required: enable "Places API (New)" in Google Cloud console.
GOOGLE_PLACES_API_KEY=your-google-maps-key-here

# 3D Tiles photogrammetry — already in your Vercel env (the editor
# uses it). Listed here for completeness; it's also the silent
# fallback for /api/places if GOOGLE_PLACES_API_KEY isn't set AND
# Places API is enabled on the same Google Cloud project.
VITE_GOOGLE_3DTILES_KEY=your-google-maps-key-here
